# Local Theseus node endpoints. Defaults match `theseus-node --dev` plus
# the `eth-rpc` proxy that exposes the Ethereum-compatible RPC.
# (Theseus uses pallet-revive / PolkaVM; eth-rpc translates JSON-RPC.)
#
#   theseus-node --dev --tmp                # WS at 9944
#   ~/.cargo/bin/eth-rpc --dev              # ETH RPC proxy at 8545
THESEUS_EVM_RPC=http://127.0.0.1:8545
THESEUS_WS=ws://127.0.0.1:9944

# Private key (0x-prefixed hex) the deployer + demo user signs with on the
# Theseus EVM. Fill in with any 32-byte hex; for local dev the address
# only needs to be pre-funded by `theseus-node --dev`. Never commit a
# real key — testnet or otherwise.
DEPLOYER_KEY=

# CLI's signing key (same key, different name) for `op deposit`, `op borrow`, etc.
OP_PRIVATE_KEY=
